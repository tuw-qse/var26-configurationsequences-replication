namespace chesspiece_product

features
        chesspieces_product {extended__ true, abstract true}
                mandatory
                        Base {abstract true}
                                alternative
                                        Base_onestrip
                                        Base_twostrip
                        Rod {abstract true}
                                alternative
                                        Rod_long
                                        Rod_short
                        Body {abstract true}
                                alternative
                                        Body_minor {abstract true}
                                                alternative
                                                        Pawn_body
                                                        Bishop_body
                                                        Rook_body
                                                        Knight_body
                                        Body_major {abstract true}
                                                alternative
                                                        Queen_body
                                                        King_body
                        PLA
                        AluminumBar

constraints
        Body_minor => Base_onestrip
        Body_major => Base_twostrip
        Body_minor => Rod_short
        Body_major => Rod_long

visibility-constraints
        Rod_short vif Body_minor
        Rod_long vif Body_major
        Base_onestrip vif Body_minor
        Base_twostrip vif Body_major
