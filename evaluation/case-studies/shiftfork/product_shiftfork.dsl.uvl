namespace shiftfork_product

features
	shiftfork_product {extended__ true, abstract true}
		mandatory
			Barrel {abstract true}
				optional
					Barrel1_2
				mandatory
					Barrel1_1
			Screw
			Jack1
			Ring1
			O_Ring
		mandatory
			Fork {abstract true}
				mandatory
					Fork3
					Fork4
					Fork5
			Pipe {abstract true}
				alternative
					Pipe3
					Pipe8
					Pipe2
			Lock {abstract true}
				alternative
					Lock3
					Lock2
					Lock1

constraints
	Pipe2 | Pipe8 => Barrel1_2
	Pipe3 => !Barrel1_2

visibility-constraints
        Lock1 vif Pipe2 | Pipe3
	Lock2 vif Pipe3
	Lock3 vif Pipe8
	Barrel1_2 vif Pipe2 | Pipe8

